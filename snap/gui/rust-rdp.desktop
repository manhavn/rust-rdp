[Desktop Entry]
Type=Application
Name=Rust RDP VNC
GenericName=Remote Desktop Client
Comment=RDP and VNC remote desktop client
Exec=rust-rdp %U
Icon=${SNAP}/meta/gui/rust-rdp.png
Terminal=false
Categories=Network;RemoteAccess;
Keywords=rdp;vnc;remote;desktop;
StartupWMClass=io.github.manhavn.rust-rdp
MimeType=application/x-rdp;application/x-vnc;
